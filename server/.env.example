# Copy to .env and fill in. Never commit the real .env.

# --- Postgres connection ---
# Easiest: one full connection string.
DATABASE_URL=postgres://user:password@host:5432/dbname
# ...or omit DATABASE_URL and set these individually instead:
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=zzsocial
# PGUSER=zzsocial
# PGPASSWORD=change-me

# --- API server ---
PORT=3001
# Secret the browser app must send in the X-App-Token header. Make it long+random.
APP_TOKEN=change-me-to-a-long-random-string
# Allowed browser origin (where you open the app). Use * to allow any origin.
# If you serve the app from the local PowerShell server, this is:
ALLOWED_ORIGIN=http://localhost:8777

# --- OpenRouter (proxied; key never reaches the browser) ---
OPENROUTER_KEY=sk-or-...
